% Background + UI
\definecolor{codebg}{RGB}{248,248,250}
\definecolor{linenumber}{RGB}{160,160,170}

% Syntax
\definecolor{keyword}{RGB}{175,95,215}     % purple (if, let, async)
\definecolor{type}{RGB}{90,160,200}        % types / enums
\definecolor{function}{RGB}{60,150,160}    % methods / functions
\definecolor{string}{RGB}{210,120,80}      % strings
\definecolor{comment}{RGB}{140,150,160}    % comments
\definecolor{number}{RGB}{80,140,200}      % numeric literals

\lstdefinestyle{light}{
  backgroundcolor=\color{codebg},
  basicstyle=\small\ttfamily\color{black},
  numbers=left,
  numberstyle=\tiny\color{linenumber},
  numbersep=5pt,
  xleftmargin=2em,
  framexleftmargin=2em,
  frame=none,
  keywordstyle=\color{keyword}\bfseries,
  commentstyle=\color{comment},
  stringstyle=\color{string},
  identifierstyle=\color{black},
  showstringspaces=false,
  showtabs=false,
  showspaces=false,
  tabsize=2,
  breaklines=true,
  breakatwhitespace=false,
  upquote=true,
}
\lstset{style=light}




